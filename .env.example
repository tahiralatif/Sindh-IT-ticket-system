# Sindh IT Ticket System — Environment Configuration

# Secret key for session signing (generate a new one for production)
SECRET_KEY=change-me-to-a-random-hex-string

# OpenRouter API key for AI department suggestions
# Leave empty to use keyword-based fallback
OPENROUTER_API_KEY=

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./sindh_tickets.db

# Rate limiting
RATE_LIMIT_LOGIN=5/minute

# Upload settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
